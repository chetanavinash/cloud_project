datasource db {
  provider = "postgresql"
  url      = env("POST_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/post-client"
}

model Post {
  id        String   @id
  authorId  String
  content   String
  mediaUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}
