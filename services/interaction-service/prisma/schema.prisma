datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

model Like {
  postId    String
  userId    String
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId])
}

model Bookmark {
  postId    String
  userId    String
  createdAt DateTime @default(now())

  @@id([postId, userId])
  @@index([userId])
}

model Comment {
  id        String    @id @default(uuid())
  postId    String
  authorId  String
  content   String
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent    Comment?  @relation("Thread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("Thread")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}
