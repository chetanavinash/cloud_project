datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

model SearchUser {
  id          String   @id
  username    String
  displayName String
  bio         String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([username])
}

model SearchPost {
  id        String   @id
  authorId  String
  content   String
  mediaUrl  String?
  createdAt DateTime
  updatedAt DateTime @default(now())

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model SearchHashtag {
  tag       String   @id
  postCount Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postCount(sort: Desc)])
}
